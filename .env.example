# Server
PORT=3008
# Set a random secret to protect all /api/* endpoints (leave blank to disable auth)
API_KEY=

# Logging: error | warn | info | debug
LOG_LEVEL=info

# Browser
# Set to "false" to run Chrome in headed mode (useful for debugging)
BROWSER_HEADLESS=true
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/96.0.4664.110 Safari/537.36

# Cloudflare Browser Run (optional — replaces local Chrome)
# Get your Account ID from the Cloudflare dashboard URL: dash.cloudflare.com/<accountId>
# Create an API Token with "Browser Rendering - Edit" permission at dash.cloudflare.com/profile/api-tokens
USE_CLOUDFLARE_BROWSER=false
CF_ACCOUNT_ID=
CF_BROWSER_TOKEN=

# ------------------------------------------------------------------
# Cloudflare R2 — result file storage
# Bucket: leadsclickvente  (already created at dae6c263806c94685f983e61690e8f21)
# S3 endpoint: https://dae6c263806c94685f983e61690e8f21.r2.cloudflarestorage.com/leadsclickvente
# Generate API token at: Cloudflare Dashboard > R2 > Manage R2 API Tokens
# Also add R2_* vars to web/.env.local so the Next.js app can read files.
# ------------------------------------------------------------------
R2_ACCOUNT_ID=dae6c263806c94685f983e61690e8f21
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=leadsclickvente

# Admin access (comma-separated email list; granted super_admin without a DB role column)
ADMIN_EMAILS=

# Supabase Postgres — transaction-mode pooler (runtime queries, port 6543)
DATABASE_URL=

# Supabase Postgres — session-mode pooler (prisma db pull / migrations, port 5432)
DIRECT_URL=

# ------------------------------------------------------------------
# Web app (Next.js) — add these to web/.env.local
# ------------------------------------------------------------------
# URL of the Express API backend (for the web app to forward enrich requests)
BACKEND_URL=http://localhost:3008
# Stripe one-time price IDs for enrichment credit top-ups
# Create these in your Stripe dashboard as one-time prices, then paste IDs here.
NEXT_PUBLIC_STRIPE_ENRICH_500_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENRICH_2000_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENRICH_5000_PRICE_ID=

# ------------------------------------------------------------------
# Cold-email outreach (web app) — connect Gmail/Outlook mailboxes and send.
# All of these go in web/.env.local.
# ------------------------------------------------------------------
# Public origin of the web app; used to build OAuth redirect + unsubscribe URLs.
# Must match the redirect URIs registered in the Google/Microsoft OAuth apps:
#   <OAUTH_REDIRECT_BASE_URL>/api/mailboxes/callback/google
#   <OAUTH_REDIRECT_BASE_URL>/api/mailboxes/callback/microsoft
OAUTH_REDIRECT_BASE_URL=http://localhost:3000
# Google OAuth (Gmail send). Create an OAuth 2.0 Client (Web) in Google Cloud
# Console and enable the Gmail API. Scope requested: gmail.send + openid/email/profile.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Microsoft OAuth (Graph Mail.Send). Register an app in Entra ID (Azure AD),
# add the redirect URI above, and grant delegated Mail.Send + User.Read + offline_access.
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# 32-byte key (base64) used for AES-256-GCM encryption of stored OAuth tokens
# AND for signing OAuth state / unsubscribe tokens. Generate with:
#   openssl rand -base64 32
EMAIL_TOKEN_ENC_KEY=
# Enrichment credits charged per email successfully sent.
CREDITS_PER_EMAIL=1
# Free emails per organization per month, drawn before paid credits. AI
# drafting (/api/campaigns/draft) is blocked while this pool still has room.
FREE_EMAILS_PER_MONTH=1000

# ------------------------------------------------------------------
# Apify LinkedIn enrichment (pay-as-you-go LinkedIn data enrichment pack)
# Create a token at https://console.apify.com/account/integrations
APIFY_TOKEN=
# Actor IDs (defaults match the plan; override to pin a version or fork)
APIFY_COMPANY_ACTOR=harvestapi/linkedin-company
APIFY_EMPLOYEES_ACTOR=harvestapi/linkedin-company-employees
APIFY_PROFILE_ACTOR=harvestapi/linkedin-profile-scraper
# Credits charged per successfully enriched row (on success only)
APIFY_CREDIT_COST_COMPANY=1
APIFY_CREDIT_COST_EMPLOYEES=2
APIFY_CREDIT_COST_PROFILE=4
# Cascade pricing: "LinkedIn profiles" scrapes each company's employees, then
# their profiles. Charged as a flat base per company + a per-profile fee that
# varies by cascade scope (decision-makers carry a premium over bulk scopes).
APIFY_CASCADE_BASE_PER_COMPANY=2
APIFY_CASCADE_PER_PROFILE_ALL=3
APIFY_CASCADE_PER_PROFILE_CAPPED=3
APIFY_CASCADE_PER_PROFILE_DECISION_MAKERS=5
# Default employee cap when the cascade scope is "capped" (Top N per company).
APIFY_CASCADE_DEFAULT_CAP=10

# ------------------------------------------------------------------
# Serper (Google Search API) — resolves each company's LinkedIn company URL
# before Apify enrichment so the actors get an exact linkedin.com/company URL.
# Get a key at https://serper.dev. Leave blank to disable (falls back to name
# search). Never commit a real key.
SERPER_API_KEY=
SERPER_ENDPOINT=https://google.serper.dev/search
# Country / language bias for the search (Serper gl/hl params)
SERPER_GL=us
SERPER_HL=en
# Max concurrent Serper requests and per-request timeout (ms)
SERPER_CONCURRENCY=4
SERPER_TIMEOUT_MS=15000

# ------------------------------------------------------------------
# OpenRouter — AI message drafts for the LinkedIn copilot extension.
# Get a key at https://openrouter.ai/keys. Any OpenAI-compatible model id
# works (e.g. openai/gpt-4o-mini, anthropic/claude-haiku-4.5). Leave the key
# blank to disable the copilot endpoint. Never commit a real key.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=500
OPENROUTER_TIMEOUT_MS=30000
# Credits charged per copilot draft or rewrite (on success only)
COPILOT_CREDIT_COST_DRAFT=1

# Scraper tuning
NAV_TIMEOUT_MS=30000
HTTP_TIMEOUT_MS=30000
CONCURRENT_LIMIT=10
MAX_UNCHANGED_SCROLLS=20
# Higher stall ceiling used only when no limit is set, so a long lazy-loading
# feed reaches its end-of-list sentinel before giving up.
MAX_UNCHANGED_SCROLLS_EXHAUST=40
MAX_QUERIES_PER_REQUEST=50
