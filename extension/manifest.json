{
  "manifest_version": 3,
  "name": "LeadClickVente LinkedIn Copilot",
  "description": "AI-drafted, personalized LinkedIn outreach. You always review and send messages yourself.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:3008/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/messaging/*"
      ],
      "js": ["content/linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
